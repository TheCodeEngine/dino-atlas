# ── PocketBase ──
POCKETBASE_ADMIN_EMAIL=admin@example.com
POCKETBASE_ADMIN_PASSWORD=         # REQUIRED — generate with: openssl rand -base64 32
POCKETBASE_URL=http://pocketbase:8090

# ── Backend (Rust) ──
JWT_SECRET=                        # REQUIRED — min 32 chars, generate with: openssl rand -base64 48
GEMINI_API_KEY=                    # Google Gemini API Key
PORT=3001
RUST_LOG=info
ALLOWED_ORIGINS=http://localhost,http://localhost:5173

# ── Generator Worker ──
# Uses same GEMINI_API_KEY, POCKETBASE_URL from above

# ── Frontend ──
VITE_API_BASE_URL=/api/v1

# ── Cloudflare Tunnel (optional) ──
# CLOUDFLARE_TUNNEL_TOKEN=
